<Window x:Class="TrafficLightClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrafficLightClient"
        mc:Ignorable="d"
        Title="TrafficLightClient" Height="175" Width="386" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Name="BtnGreen" Width="80" Height="80" Margin="4" Click="BtnGreen_Click">
                <StackPanel>
                    <Grid Width="48" Height="48">
                        <Ellipse Fill="LimeGreen" Stroke="Black" StrokeThickness="1" />
                    </Grid>
                    <TextBlock Text="Green" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Name="BtnYellow" Width="80" Height="80" Margin="4" Click="BtnYellow_Click">
                <StackPanel>
                    <Grid Width="48" Height="48">
                        <Ellipse Fill="Yellow" Stroke="Black" StrokeThickness="1" />
                    </Grid>
                    <TextBlock Text="Yellow" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Name="BtnRed" Width="80" Height="80" Margin="4" Click="BtnRed_Click">
                <StackPanel>
                    <Grid Width="48" Height="48">
                        <Ellipse Fill="Red" Stroke="Black" StrokeThickness="1" />
                    </Grid>
                    <TextBlock Text="Red" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Name="BtnInactive" Width="80" Height="80" Margin="4" Click="BtnInactive_Click">
                <StackPanel>
                    <Grid Width="48" Height="48">
                        <Ellipse x:Name="BlinkEllipse" Fill="Orange" Stroke="Black" StrokeThickness="1" Opacity="1" />
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Button.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="BlinkEllipse" Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.5" AutoReverse="True" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                    </Grid>
                    <TextBlock Text="Inactive" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,10">
            <CheckBox Name="ChkCpu" Content="Enable CPU load switching" Checked="ChkCpu_Checked" Unchecked="ChkCpu_Unchecked" />
            <TextBlock Name="TxtStatus" Margin="16,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

    </Grid>
</Window>
